{
  "component": "Avatar",
  "figma_page": "03.05 Avatar",
  "figma_page_id": "50861:237696",
  "description": "用户头像组件，支持单个头像、头像组和带状态徽标的 Echo 形态。内容社区中用于作者信息、评论列表、用户主页。",
  "usage_rules": [
    "内容卡片作者信息用 Normal(40px) 尺寸",
    "评论列表用 Small(32px) 尺寸",
    "用户主页大头像用 Large(64px)",
    "Echo/AvatarLive 用于直播状态展示",
    "Grouped 用于多人参与的场景（共同关注、群组等）"
  ],
  "variants": {
    "Basic": {
      "figma_name": "💙 03.05_Avatar / Basic",
