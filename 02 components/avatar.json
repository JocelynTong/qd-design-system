        "Size": { "options": ["Large", "Medium", "Normal", "Small", "Mini"] },
        "className": {
          "options": ["AvatarReddot", "AvatarNumberReddot", "AvatarGender", "AvatarOnline", "AvatarLive"],
          "desc": {
            "AvatarReddot": "红点未读提示",
            "AvatarNumberReddot": "数字角标",
            "AvatarGender": "性别标识",
            "AvatarOnline": "在线状态",
            "AvatarLive": "直播中状态"
          }
        }
      }
