        "Size": {
          "options": ["Large", "Medium", "Normal", "Small", "Mini"],
          "sizes_px": { "Large": 64, "Medium": 48, "Normal": 40, "Small": 32, "Mini": 24 }
        },
        "Color": {
          "options": ["Primary", "Online", "Error", "Default", "Trade", "White"],
          "desc": {
            "Primary": "主品牌色边框",
            "Online": "在线状态（绿色边框）",
            "Error": "异常状态（红色边框）",
            "Default": "默认无边框",
            "Trade": "交易场景强调",
            "White": "白色边框（深色背景上使用）"
          }
        }
      }
    },
    "Grouped": {
      "figma_name": "💙 03.05_Avatar / Grouped",
      "desc": "头像组，展示多个用户（如共同关注）",
      "props": {
        "Size": { "options": ["Large", "Medium", "Normal", "Small", "Mini"] },
        "Count": { "options": ["1", "2", "3", "4", "5"], "desc": "显示的头像数量" },
        "Spacing": {
          "options": ["Large", "Small", "--"],
          "desc": { "Large": "头像间距大", "Small": "头像叠加", "--": "自定义" }
        },
        "Sequence": {
          "options": ["PositiveOrder", "ReverseOrder", "--"],
          "desc": { "PositiveOrder": "正序叠加", "ReverseOrder": "逆序叠加" }
        }
      }
    },
    "Echo": {
      "figma_name": "💙 03.05_Avatar / Echo",
